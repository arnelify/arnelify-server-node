{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noImplicitAny": true,
    "outDir": "./build",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "strict": true,
    "target": "ES2020",
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["tests", "node_modules", "build"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
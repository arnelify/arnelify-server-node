{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "commonjs",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "outDir": "./build",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "strict": true,
    "target": "ES2020"
  },
  "include": ["src"],
  "exclude": ["tests", "node_modules", "build"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}